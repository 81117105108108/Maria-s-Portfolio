# Database (SQLite file in project root)
DATABASE_URL="file:./dev.db"

# NextAuth (required for JWT signing)
NEXTAUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary (required for image uploads)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_UPLOAD_PRESET="maria_portfolio"

# Public Cloudinary (safe in browser - cloud name used in image URLs)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# Seed admin accounts (change these to real emails before production)
ADMIN_EMAIL="your-admin-email@domain.com"
ADMIN_PASSWORD="change-this-secure-password"
MARIA_EMAIL="maria@domain.com"
MARIA_PASSWORD="change-this-secure-password"

# Webhook secret (for Cloudinary revalidation webhook)
REVALIDATION_SECRET="change-me-generate-with-openssl-rand-base64-32"

# Contact form recipient
CONTACT_EMAIL="your-email@domain.com"